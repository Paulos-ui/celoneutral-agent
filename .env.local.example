# Frontend environment — copy to .env.local
# WalletConnect Cloud project id (free at https://cloud.reown.com)
NEXT_PUBLIC_WALLETCONNECT_ID=
# Deployed vault contract address (fill after deploy)
NEXT_PUBLIC_VAULT_ADDRESS=
# Stablecoin the vault accepts (cUSD mainnet by default)
NEXT_PUBLIC_STABLE_ADDRESS=0x765DE816845861e75A25fCA122bb6898B8B1282a
# ERC-8004 agentId once registered (shown as a badge on the site)
NEXT_PUBLIC_AGENT_ID=
