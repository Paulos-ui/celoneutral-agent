{
  "name": "celoneutral-contracts",
  "version": "1.0.0",
  "scripts": {
    "compile": "hardhat compile",
    "deploy:testnet": "hardhat run scripts/deploy.ts --network alfajores",
    "deploy:mainnet": "hardhat run scripts/deploy.ts --network celo",
    "register": "hardhat run scripts/registerAgent.ts --network celo",
    "verify": "hardhat verify --network celo",
    "deploy:celo": "TOKEN=CELO hardhat run scripts/deploy.ts --network celo"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "hardhat": "^2.22.0",
    "typescript": "^5",
    "ts-node": "^10.9.2",
    "dotenv": "^16.4.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.1.0"
  }
}